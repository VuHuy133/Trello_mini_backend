# JWT Configuration
# JWT_SECRET must be at least 32 characters for HS256 signing
# Example: TrelloMiniSecretKey1234567890Trello
JWT_SECRET=-

# JWT expiration in seconds (default: 86400 = 1 day)
JWT_EXPIRATION=86400

# OAuth2 Google Login Configuration
# Get credentials from: https://console.cloud.google.com/
# Steps:
#   1. Create new OAuth2 Web Application credential
#   2. Add redirect URI: http://localhost:8088/login/oauth2/code/google
#   3. Copy Client ID and Secret below
# NOTE: These are REQUIRED for OAuth2 Google login to work
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_NAME=trello
DB_USERNAME=root
DB_PASSWORD=123456

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Spring Configuration
SPRING_PROFILES_ACTIVE=docker
